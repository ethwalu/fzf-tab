#!/hint/zsh
# -ftb-translate: 在 -ftb-generate-complist 前替换 _ftb_compcap 中的英文描述
#
# 触发条件：zstyle ':fzf-tab:*' translate true
# API 密钥：export FTB_DEEPL_KEY="your-key:fx"
# 调试日志：export FTB_TRANSLATE_DEBUG=1
#           日志文件：$FTB_TRANSLATE_CACHE_DIR/debug.log
#
# _ftb_compcap 元素格式：
#   <description>\x02<metadata>
# description 通常为 "word -- english description"
# metadata 中含 \x00word\x00<actual_word>
#
# 缓存策略：以英文描述为 key，翻译结果为 value。
# 同一描述在不同命令上下文（如 docker 和 docker image）下总能命中相同翻译。

# 首次调用时懒加载翻译模块
if [[ -z "$_ftb_tr_initialized" ]]; then
  source "$FZF_TAB_HOME/lib/translate/init.zsh"
  source "$FZF_TAB_HOME/lib/translate/utils.zsh"
  source "$FZF_TAB_HOME/lib/translate/cache.zsh"
  source "$FZF_TAB_HOME/lib/translate/key.zsh"
  source "$FZF_TAB_HOME/lib/translate/deepl.zsh"
  source "$FZF_TAB_HOME/lib/translate/trans.zsh"
  typeset -g _ftb_tr_initialized=1
  _ftb_tr_log info "翻译模块初始化完成（API=$FTB_TRANSLATE_API, LANG=$FTB_TRANSLATE_LANG）"
fi

(( $#_ftb_compcap == 0 )) && return

# 用 BUFFER 第一个词作为缓存文件名，保证每次 TAB 结果一致
# curcontext 中的函数名（如 _docker-image-）在不同调用间可能不同，导致缓存文件命中失败
local _tr_cmd="${${BUFFER## #}%% *}"
# 将命令名中的连字符替换为下划线，确保可用作 zsh 变量名和缓存文件名
_tr_cmd="${_tr_cmd//-/_}"
if [[ -z "$_tr_cmd" ]]; then
  _ftb_tr_log debug "BUFFER 为空，跳过翻译（curcontext=$_ftb_curcontext）"
  return
fi

# 仅当 BUFFER 中有空格时才翻译（即命令已输完，正在补全参数或子命令）
# 若没有空格，说明用户仍在补全命令名本身（如 ssh-co<TAB>），不应翻译
if [[ "${BUFFER## #}" != *" "* ]]; then
  _ftb_tr_log debug "BUFFER 无空格，跳过翻译（仍在补全命令名）: $BUFFER"
  return
fi
_ftb_tr_log debug "检测到命令: $_tr_cmd (curcontext=$_ftb_curcontext, compcap=${#_ftb_compcap[@]} 条)"

# 每次重新从磁盘加载缓存（后台翻译完成后可能有新数据）
_ftb_tr_cache_load "$_tr_cmd" 2>/dev/null

local _tr_cache_var="_ftb_tr_cache_${_tr_cmd}"
(( ${(P)+_tr_cache_var} )) || typeset -gA "$_tr_cache_var"

# 遍历 _ftb_compcap，替换已缓存的描述，收集未缓存的
# 缓存 key 为英文描述文本，避免同名 word 在不同子命令上下文中命中错误翻译
local -a _tr_new_compcap=()
local -a _tr_uncached_descs=()
local _tr_item _tr_dscr _tr_meta _tr_word _tr_eng _tr_result
local _tr_hits=0

for _tr_item in "${_ftb_compcap[@]}"; do
  _tr_dscr="${_tr_item%%$'\2'*}"
  _tr_meta="${_tr_item#*$'\2'}"
  _tr_word="${_tr_meta##*$'\0word\0'}"
  _tr_word="${_tr_word%%$'\0'*}"

  if [[ "$_tr_dscr" == *" -- "* ]]; then
    _tr_eng="${_tr_dscr#* -- }"
  else
    _tr_eng=""
  fi

  # 以英文描述为 key 查缓存（用 eval 间接访问关联数组，${${(P)var}[key]} 对 assoc array 不生效）
  _tr_result=""
  [[ -n "$_tr_eng" ]] && eval "_tr_result=\${${_tr_cache_var}[${(q)_tr_eng}]}"

  if [[ -n "$_tr_eng" && -n "$_tr_result" ]]; then
    (( _tr_hits++ ))
    _tr_new_compcap+=("${_tr_dscr%% -- *} -- ${_tr_result}"$'\2'"${_tr_meta}")
  else
    _tr_new_compcap+=("$_tr_item")
    if [[ -n "$_tr_eng" && -z "$_tr_result" ]]; then
      _tr_uncached_descs+=("$_tr_eng")
    fi
  fi
done

_ftb_tr_log debug "替换统计: 总计=${#_ftb_compcap[@]} 命中=$_tr_hits 未缓存=${#_tr_uncached_descs[@]}"
_ftb_compcap=("${_tr_new_compcap[@]}")

# 有未缓存条目且无后台翻译进行中，启动异步翻译
if (( ${#_tr_uncached_descs[@]} == 0 )); then
  return
fi

local _tr_lock="${FTB_TRANSLATE_CACHE_DIR}/.translating_${_tr_cmd}"
if [[ -f "$_tr_lock" ]]; then
  _ftb_tr_log debug "后台翻译进行中，跳过: $_tr_cmd"
  return
fi

touch "$_tr_lock"
_ftb_tr_log info "启动后台翻译: $_tr_cmd (${#_tr_uncached_descs[@]} 条)"

# 将待翻译英文描述写入临时文件，每行一条
local _tr_tmp="${FTB_TRANSLATE_CACHE_DIR}/.pending_${_tr_cmd}.tsv"
{
  local _tr_desc
  for _tr_desc in "${_tr_uncached_descs[@]}"; do
    print -r -- "$_tr_desc"
  done
} > "$_tr_tmp"

# 启动独立 zsh 进程在后台完成翻译并写回缓存
FZF_TAB_HOME="$FZF_TAB_HOME" \
FTB_TRANSLATE_API="$FTB_TRANSLATE_API" \
FTB_TRANSLATE_LANG="$FTB_TRANSLATE_LANG" \
FTB_TRANSLATE_TIMEOUT="$FTB_TRANSLATE_TIMEOUT" \
FTB_TRANSLATE_CHUNK_SIZE="$FTB_TRANSLATE_CHUNK_SIZE" \
FTB_TRANSLATE_ENGINE="${FTB_TRANSLATE_ENGINE:-google}" \
FTB_TRANSLATE_CACHE_DIR="$FTB_TRANSLATE_CACHE_DIR" \
FTB_TRANSLATE_KEY_DIR="$FTB_TRANSLATE_KEY_DIR" \
FTB_TRANSLATE_DEBUG="$FTB_TRANSLATE_DEBUG" \
FTB_DEEPL_KEY="${FTB_DEEPL_KEY:-}" \
zsh -c '
  source "$FZF_TAB_HOME/lib/translate/init.zsh"
  source "$FZF_TAB_HOME/lib/translate/utils.zsh"
  source "$FZF_TAB_HOME/lib/translate/cache.zsh"
  source "$FZF_TAB_HOME/lib/translate/key.zsh"
  source "$FZF_TAB_HOME/lib/translate/deepl.zsh"
  source "$FZF_TAB_HOME/lib/translate/trans.zsh"

  local cmd="$1" tmp="$2"
  local cache_var="_ftb_tr_cache_${cmd}"
  local _lock="${FTB_TRANSLATE_CACHE_DIR}/.translating_${cmd}"

  _ftb_tr_log info "[后台] 启动: $cmd"

  # 加载现有缓存（如有）
  _ftb_tr_cache_load "$cmd" 2>/dev/null
  typeset -gA "$cache_var" 2>/dev/null

  # 读取待翻译英文描述，每行一条
  local -a descs=()
  local d
  while IFS= read -r d; do
    descs+=("$d")
  done < "$tmp"
  rm -f "$tmp"

  if (( ${#descs[@]} == 0 )); then
    _ftb_tr_log warn "[后台] 待翻译列表为空: $cmd"
    rm -f "$_lock"
    return
  fi

  _ftb_tr_log info "[后台] 开始翻译: $cmd (${#descs[@]} 条)"

  # 根据 API 类型调用相应翻译后端
  local -a translations
  case "$FTB_TRANSLATE_API" in
    trans)
      translations=("${(@f)$(_ftb_tr_trans_batch "${descs[@]}")}")
      ;;
    deepl|*)
      translations=("${(@f)$(_ftb_tr_deepl_batch "${descs[@]}")}")
      ;;
  esac

  # 验证翻译结果行数与输入一致，不一致说明 trans 输出格式有问题
  if (( ${#translations[@]} != ${#descs[@]} )); then
    _ftb_tr_log error "[后台] 翻译结果行数不匹配: 输入=${#descs[@]} 输出=${#translations[@]}，丢弃结果"
    rm -f "$_lock"
    return 1
  fi

  if (( ${#translations[@]} == 0 )); then
    _ftb_tr_log error "[后台] 翻译失败，无结果返回: $cmd"
    rm -f "$_lock"
    return 1
  fi

  # 以英文描述为 key 写入缓存
  # 用 (q) 标志对 key/value 正确引号，避免含空格时 eval 出错
  local i
  for (( i=1; i<=${#descs[@]}; i++ )); do
    [[ -n "${translations[$i]}" ]] || continue
    eval "${cache_var}[${(q)descs[$i]}]=${(q)translations[$i]}"
  done

  _ftb_tr_cache_save "$cmd"
  rm -f "$_lock"
  _ftb_tr_log info "[后台] 完成: $cmd"
' -- "$_tr_cmd" "$_tr_tmp" </dev/null >/dev/null 2>/dev/null &!
