#!/hint/zsh
# -ftb-translate: 在 -ftb-generate-complist 前替换 _ftb_compcap 中的英文描述
#
# 触发条件：zstyle ':fzf-tab:*' translate true
# API 密钥：export FTB_DEEPL_KEY="your-key:fx"
# 调试日志：export FTB_TRANSLATE_DEBUG=1
#           日志文件：$FTB_TRANSLATE_CACHE_DIR/debug.log
#
# _ftb_compcap 元素格式：
#   <description>\x02<metadata>
# description 通常为 "word -- english description"
# metadata 中含 \x00word\x00<actual_word>

# 重置异步标志（每次 TAB 开始时清零，启动后台进程时置 1）
typeset -g _ftb_tr_async_started=0

# 首次调用时懒加载翻译模块
if [[ -z "$_ftb_tr_initialized" ]]; then
  source "$FZF_TAB_HOME/lib/translate/init.zsh"
  source "$FZF_TAB_HOME/lib/translate/utils.zsh"
  source "$FZF_TAB_HOME/lib/translate/cache.zsh"
  source "$FZF_TAB_HOME/lib/translate/key.zsh"
  source "$FZF_TAB_HOME/lib/translate/deepl.zsh"
  typeset -g _ftb_tr_initialized=1
  _ftb_tr_log info "翻译模块初始化完成（API=$FTB_TRANSLATE_API, LANG=$FTB_TRANSLATE_LANG）"
fi

(( $#_ftb_compcap == 0 )) && return

# 从补全上下文检测当前命令名
local _tr_cmd=""
if [[ -n "$_ftb_curcontext" ]]; then
  local -a _tr_ctx=("${(@s.:.)_ftb_curcontext}")
  local _tr_i
  for (( _tr_i=1; _tr_i<=${#_tr_ctx[@]}; _tr_i++ )); do
    if [[ "${_tr_ctx[$_tr_i]}" == "complete" && -n "${_tr_ctx[$((_tr_i+1))]}" ]]; then
      _tr_cmd="${_tr_ctx[$((_tr_i+1))]}"
      break
    fi
  done
fi
[[ -z "$_tr_cmd" && -n "$BUFFER" ]] && _tr_cmd="${${BUFFER## #}%% *}"
if [[ -z "$_tr_cmd" ]]; then
  _ftb_tr_log debug "未检测到命令，跳过翻译（curcontext=$_ftb_curcontext）"
  return
fi
_ftb_tr_log debug "检测到命令: $_tr_cmd (curcontext=$_ftb_curcontext, compcap=${#_ftb_compcap[@]} 条)"

# 每次重新从磁盘加载缓存（后台翻译完成后可能有新数据）
_ftb_tr_cache_load "$_tr_cmd" 2>/dev/null

local _tr_cache_var="_ftb_tr_cache_${_tr_cmd}"
(( ${(P)+_tr_cache_var} )) || typeset -gA "$_tr_cache_var"

# 遍历 _ftb_compcap，替换已缓存的描述，收集未缓存的
local -a _tr_new_compcap=()
local -a _tr_uncached_words=() _tr_uncached_descs=()
local _tr_item _tr_dscr _tr_meta _tr_word _tr_eng _tr_result
local _tr_hits=0

for _tr_item in "${_ftb_compcap[@]}"; do
  _tr_dscr="${_tr_item%%$'\2'*}"
  _tr_meta="${_tr_item#*$'\2'}"
  _tr_word="${_tr_meta##*$'\0word\0'}"
  _tr_word="${_tr_word%%$'\0'*}"

  _tr_result="${${(P)_tr_cache_var}[$_tr_word]}"

  if [[ -n "$_tr_result" ]]; then
    (( _tr_hits++ ))
    # 替换 -- 后面的英文描述为翻译结果
    if [[ "$_tr_dscr" == *" -- "* ]]; then
      _tr_new_compcap+=("${_tr_dscr%% -- *} -- ${_tr_result}"$'\2'"${_tr_meta}")
    else
      _tr_new_compcap+=("${_tr_word} -- ${_tr_result}"$'\2'"${_tr_meta}")
    fi
  else
    _tr_new_compcap+=("$_tr_item")
    # 收集有英文描述的未缓存条目
    if [[ "$_tr_dscr" == *" -- "* ]]; then
      _tr_eng="${_tr_dscr#* -- }"
      if [[ -n "$_tr_eng" ]]; then
        _tr_uncached_words+=("$_tr_word")
        _tr_uncached_descs+=("$_tr_eng")
      fi
    fi
  fi
done

_ftb_tr_log debug "替换统计: 总计=${#_ftb_compcap[@]} 命中=$_tr_hits 未缓存=${#_tr_uncached_words[@]}"
_ftb_compcap=("${_tr_new_compcap[@]}")

# 有未缓存条目且无后台翻译进行中，启动异步翻译
if (( ${#_tr_uncached_words[@]} == 0 )); then
  return
fi

local _tr_lock="${FTB_TRANSLATE_CACHE_DIR}/.translating_${_tr_cmd}"
if [[ -f "$_tr_lock" ]]; then
  _ftb_tr_log debug "后台翻译进行中，跳过: $_tr_cmd"
  return
fi

touch "$_tr_lock"
_ftb_tr_log info "启动后台翻译: $_tr_cmd (${#_tr_uncached_words[@]} 条)"

# 通知 -ftb-fzf 需要开启 --listen 以便翻译完成后刷新 UI
typeset -g _ftb_tr_async_started=1

# 将待翻译条目写入临时文件（word\tdesc 格式，每行一条）
local _tr_tmp="${FTB_TRANSLATE_CACHE_DIR}/.pending_${_tr_cmd}.tsv"
{
  local _tr_j
  for (( _tr_j=1; _tr_j<=${#_tr_uncached_words[@]}; _tr_j++ )); do
    print -r -- "${_tr_uncached_words[$_tr_j]}"$'\t'"${_tr_uncached_descs[$_tr_j]}"
  done
} > "$_tr_tmp"

# fzf 临时文件目录（与 -ftb-fzf 使用相同路径）
local _tr_parent_pid="$$"
local _tr_fzf_tmp="${TMPPREFIX:-/tmp/zsh}-fzf-tab-${USER}"

# 启动独立 zsh 进程在后台完成翻译并写回缓存，完成后刷新 fzf UI
FZF_TAB_HOME="$FZF_TAB_HOME" \
FTB_TRANSLATE_API="$FTB_TRANSLATE_API" \
FTB_TRANSLATE_LANG="$FTB_TRANSLATE_LANG" \
FTB_TRANSLATE_TIMEOUT="$FTB_TRANSLATE_TIMEOUT" \
FTB_TRANSLATE_CACHE_DIR="$FTB_TRANSLATE_CACHE_DIR" \
FTB_TRANSLATE_KEY_DIR="$FTB_TRANSLATE_KEY_DIR" \
FTB_TRANSLATE_DEBUG="$FTB_TRANSLATE_DEBUG" \
FTB_DEEPL_KEY="${FTB_DEEPL_KEY:-}" \
zsh -c '
  source "$FZF_TAB_HOME/lib/translate/init.zsh"
  source "$FZF_TAB_HOME/lib/translate/utils.zsh"
  source "$FZF_TAB_HOME/lib/translate/cache.zsh"
  source "$FZF_TAB_HOME/lib/translate/key.zsh"
  source "$FZF_TAB_HOME/lib/translate/deepl.zsh"

  local cmd="$1" tmp="$2" parent_pid="$3" fzf_tmp="$4"
  local cache_var="_ftb_tr_cache_${cmd}"
  local completions_file="$fzf_tmp/completions.$parent_pid"
  local port_file="$fzf_tmp/fzf_listen.$parent_pid"

  _ftb_tr_log info "[后台] 启动: $cmd"

  # 加载现有缓存（如有）
  _ftb_tr_cache_load "$cmd" 2>/dev/null
  typeset -gA "$cache_var" 2>/dev/null

  # 读取待翻译条目
  local -a words=() descs=()
  local w d
  while IFS=$'"'"'\t'"'"' read -r w d; do
    words+=("$w")
    descs+=("$d")
  done < "$tmp"
  rm -f "$tmp"

  if (( ${#descs[@]} == 0 )); then
    _ftb_tr_log warn "[后台] 待翻译列表为空: $cmd"
    rm -f "${FTB_TRANSLATE_CACHE_DIR}/.translating_${cmd}"
    return
  fi

  _ftb_tr_log info "[后台] 开始翻译: $cmd (${#descs[@]} 条)"

  # 批量调用 DeepL
  local -a translations=("${(@f)$(_ftb_tr_deepl_batch "${descs[@]}")}")

  if (( ${#translations[@]} == 0 )); then
    _ftb_tr_log error "[后台] 翻译失败，无结果返回: $cmd"
    rm -f "${FTB_TRANSLATE_CACHE_DIR}/.translating_${cmd}"
    return 1
  fi

  # 写入缓存
  local i k v
  for (( i=1; i<=${#words[@]}; i++ )); do
    [[ -n "${translations[$i]}" ]] || continue
    k="${words[$i]}"
    v="${translations[$i]}"
    eval "${cache_var}[\$k]=\$v"
  done

  _ftb_tr_cache_save "$cmd"
  rm -f "${FTB_TRANSLATE_CACHE_DIR}/.translating_${cmd}"
  _ftb_tr_log info "[后台] 缓存已写入: $cmd"

  # ── 刷新 fzf UI ──────────────────────────────────────────────────────────
  # 等待 -ftb-fzf 写入端口文件（fzf --listen 启动后才写入）
  # 翻译 API 通常需要 1-3s，fzf 启动 <0.1s，大多数情况下端口文件已存在
  local _wait=0
  while [[ ! -f "$port_file" ]] && (( _wait < 50 )); do
    sleep 0.1
    (( _wait++ ))
  done

  if [[ ! -f "$port_file" || ! -f "$completions_file" ]]; then
    _ftb_tr_log debug "[后台] fzf 已退出或不支持 --listen，跳过 UI 刷新"
    return
  fi

  local fzf_port=$(<"$port_file")
  _ftb_tr_log info "[后台] 准备更新 fzf UI (port=$fzf_port)"

  # 将 (word, orig_desc, translation) 写入临时 TSV 文件
  # 用 parent_pid 保证文件名唯一，避免并发冲突
  local pairs_file="${FTB_TRANSLATE_CACHE_DIR}/.pairs_${cmd}_${parent_pid}.tsv"
  for (( i=1; i<=${#words[@]}; i++ )); do
    [[ -n "${translations[$i]}" ]] || continue
    print -r -- "${words[$i]}"$'\t'"${descs[$i]}"$'\t'"${translations[$i]}"
  done > "$pairs_file"
  _ftb_tr_log debug "[后台] pairs_file 已写入: $(wc -l < "$pairs_file") 条"

  # 调用独立 Python 脚本替换 completions 文件中的英文描述
  # 独立脚本彻底规避三层引号的转义问题
  if "$_FTB_TR_PYTHON" "$FZF_TAB_HOME/lib/translate/update_completions.py" \
      "$completions_file" "$pairs_file" 2>>"$_FTB_TR_LOG_FILE"; then
    _ftb_tr_log info "[后台] completions 文件已更新"
  else
    _ftb_tr_log warn "[后台] completions 文件更新失败"
  fi
  rm -f "$pairs_file"

  # 向 fzf --listen 发送 reload 命令，刷新补全列表
  # 若 fzf 尚未就绪则重试（最多 3 秒），端口文件消失（fzf 已退出）则立即放弃
  local _tries=0
  while [[ -f "$port_file" ]] && (( _tries < 30 )); do
    if curl -s --max-time 1 "http://127.0.0.1:$fzf_port" \
        -d "reload:cat $completions_file" 2>/dev/null; then
      _ftb_tr_log info "[后台] fzf reload 命令已发送"
      break
    fi
    sleep 0.1
    (( _tries++ ))
  done
' -- "$_tr_cmd" "$_tr_tmp" "$_tr_parent_pid" "$_tr_fzf_tmp" \
  </dev/null >/dev/null 2>/dev/null &!
